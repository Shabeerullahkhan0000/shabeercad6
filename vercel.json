{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm nx run-many -t build --projects=cad-simple-viewer,cad-simple-viewer-example --parallel=false",
  "outputDirectory": "packages/cad-simple-viewer-example/dist",
  "installCommand": "pnpm install",
  "framework": null,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" }
      ]
    }
  ]
}
